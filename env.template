# =============================================================================
# KOMMZ VOICE - ENV TEMPLATE
# Copy to `.env` and fill with real values. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------
FLASK_ENV=production
PORT=5000
SECRET_KEY=CHANGE_ME_FLASK_SECRET_64_HEX

# -----------------------------------------------------------------------------
# Supabase (SERVER SIDE ONLY)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Must be service_role, never anon
SUPABASE_KEY=CHANGE_ME_SUPABASE_SERVICE_ROLE

# -----------------------------------------------------------------------------
# Modal endpoints
# -----------------------------------------------------------------------------
MODAL_WHISPER_URL=https://YOUR_APP--whisper-transcribe.modal.run
MODAL_XTTS_URL=https://YOUR_APP--kommz-voice-xtts.modal.run

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
VOICE_SECRET_SALT=CHANGE_ME_VOICE_SALT
DESKTOP_SECRET_SALT=CHANGE_ME_DESKTOP_SALT
PASSWORD_SALT=CHANGE_ME_PASSWORD_SALT
ADMIN_SECRET=CHANGE_ME_ADMIN_SECRET_LONG_RANDOM
TRIAL_WINDOW_HOURS=24
TRIAL_MAX_AUDIO_SECONDS=1800
TRIAL_MAX_GENERATIONS=120

# -----------------------------------------------------------------------------
# Desktop integrations
# -----------------------------------------------------------------------------
DEEPL_AUTH_KEY=CHANGE_ME_DEEPL_AUTH_KEY

# -----------------------------------------------------------------------------
# Optional notifications
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=CHANGE_ME_SENDGRID_API_KEY
ADMIN_EMAIL=admin@example.com
