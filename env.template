# =============================================================================
# KOMMZ VOICE - ENV TEMPLATE
# Copy to `.env` and fill with real values. Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------
FLASK_ENV=production
PORT=5000
SECRET_KEY=CHANGE_ME_FLASK_SECRET_64_HEX

# -----------------------------------------------------------------------------
# Supabase (SERVER SIDE ONLY)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Must be service_role, never anon
SUPABASE_KEY=CHANGE_ME_SUPABASE_SERVICE_ROLE
STORAGE_BUCKET=voice-references
STORAGE_ALLOW_PUBLIC_FALLBACK=0

# -----------------------------------------------------------------------------
# Modal endpoints
# -----------------------------------------------------------------------------
MODAL_WHISPER_URL=https://YOUR_APP--whisper-transcribe.modal.run
MODAL_XTTS_URL=https://YOUR_APP--kommz-voice-xtts.modal.run
# Optional explicit warmup endpoint (defaults to {MODAL_XTTS_URL}/warmup)
MODAL_XTTS_WARMUP_URL=https://YOUR_APP--kommz-voice-xtts-warmup.modal.run

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
VOICE_SECRET_SALT=CHANGE_ME_VOICE_SALT
DESKTOP_SECRET_SALT=CHANGE_ME_DESKTOP_SALT
PASSWORD_SALT=CHANGE_ME_PASSWORD_SALT
ADMIN_SECRET=CHANGE_ME_ADMIN_SECRET_LONG_RANDOM
TRIAL_WINDOW_HOURS=24
TRIAL_MAX_AUDIO_SECONDS=1800
TRIAL_MAX_GENERATIONS=120
TRIAL_REGISTER_RATE_LIMIT_PER_10MIN=6
TRIAL_ACTIVATE_RATE_LIMIT_PER_10MIN=12
TRIAL_GUARD_ENABLED=1
TRIAL_GUARD_WINDOW_SECONDS=600

# -----------------------------------------------------------------------------
# Desktop integrations
# -----------------------------------------------------------------------------
DEEPL_AUTH_KEY=CHANGE_ME_DEEPL_AUTH_KEY
DESKTOP_STABLE_VERSION=4.1
DESKTOP_DOWNLOAD_URL=https://github.com/YOUR_ORG/YOUR_REPO/releases/download/v4.1/Kommz_Diamond_v4.1.exe
DESKTOP_DOWNLOAD_SHA256=CHANGE_ME_SHA256_OF_EXE
DESKTOP_CHANGELOG_URL=https://github.com/YOUR_ORG/YOUR_REPO/releases/tag/v4.1
DESKTOP_FORCE_UPDATE=0
DESKTOP_MINIMUM_VERSION=4.0.0

# -----------------------------------------------------------------------------
# Optional notifications
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=CHANGE_ME_SENDGRID_API_KEY
ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Twilio / Kommz Access calling bridge
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=CHANGE_ME_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=CHANGE_ME_TWILIO_AUTH_TOKEN
TWILIO_API_KEY_SID=CHANGE_ME_TWILIO_API_KEY_SID
TWILIO_API_KEY_SECRET=CHANGE_ME_TWILIO_API_KEY_SECRET
TWILIO_TWIML_APP_SID=CHANGE_ME_TWILIO_TWIML_APP_SID
TWILIO_DEFAULT_IDENTITY=kommz-access-agent
TWILIO_PUBLIC_BASE_URL=https://YOUR_ACCESS_CALL_BRIDGE.onrender.com
TWILIO_ALLOWED_ORIGINS=https://YOUR_ACCESS_APP_DOMAIN
# Optional during rollout. Leave empty until the client sends Authorization / X-Bridge-Secret.
TWILIO_BRIDGE_SECRET=CHANGE_ME_TWILIO_BRIDGE_SECRET
TWILIO_TRANSCRIPTION_LANGUAGE=fr-FR
TWILIO_TRANSCRIPTION_ENGINE=google
TWILIO_TRANSCRIPTION_MODEL=telephony
TWILIO_TOKEN_TTL=3600
