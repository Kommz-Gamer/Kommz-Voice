# Production environment template for Render/containers.
# Fill with rotated values only.

FLASK_ENV=production
PORT=5000

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=CHANGE_ME_SUPABASE_SERVICE_ROLE
STORAGE_BUCKET=voice-references
STORAGE_ALLOW_PUBLIC_FALLBACK=0

MODAL_WHISPER_URL=https://YOUR_APP--whisper-transcribe.modal.run
MODAL_XTTS_URL=https://YOUR_APP--kommz-voice-xtts.modal.run

SECRET_KEY=CHANGE_ME_FLASK_SECRET_64_HEX
VOICE_SECRET_SALT=CHANGE_ME_VOICE_SALT
PASSWORD_SALT=CHANGE_ME_PASSWORD_SALT
ADMIN_SECRET=CHANGE_ME_ADMIN_SECRET_LONG_RANDOM
TWILIO_AUTH_TOKEN=CHANGE_ME_TWILIO_AUTH_TOKEN
TWILIO_ALLOWED_ORIGINS=https://YOUR_ACCESS_APP_DOMAIN
# Optional during rollout. Leave empty until the client sends Authorization / X-Bridge-Secret.
TWILIO_BRIDGE_SECRET=CHANGE_ME_TWILIO_BRIDGE_SECRET
